# Database (used by docker-compose and DATABASE_URL)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=  # Set strong password for production
POSTGRES_DB=ultima_forma
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:55432/ultima_forma

# API Ports (optional - defaults shown)
API_GATEWAY_PORT=3333
ORCHESTRATION_API_PORT=3334

# User App (para consentUrl retornada pelo api-gateway)
# - localhost:8081: fluxo web no mesmo computador
# - Se testar no celular: use o IP da sua máquina na LAN (ex: http://192.168.1.5:8081)
USER_APP_URL=http://localhost:8081

# Expo user-app: API base URL injected into the web bundle
EXPO_PUBLIC_API_URL=http://localhost:3333

# Node
NODE_ENV=development
