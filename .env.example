# ============================================================
# Ultima Forma MVP - Environment template
# Copy to .env and fill values. For production simulation locally,
# generate keys below and set NODE_ENV=development (localhost DB allowed).
# ============================================================

# Database (used by docker-compose and DATABASE_URL)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ultima_forma
# Production: replace localhost with your DB host
DATABASE_URL=postgresql://postgres:postgres@localhost:55432/ultima_forma

# API Ports
API_GATEWAY_PORT=3333
ORCHESTRATION_API_PORT=3334
WORKER_PORT=3335

# Internal API key - REQUIRED for production. Protects /internal/* (orchestration-api).
# Ops Console sends via X-API-Key. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_KEY=

# User App (consentUrl) - use LAN IP when testing on mobile
USER_APP_URL=http://localhost:8081

# Expo user-app - API URL in web bundle
EXPO_PUBLIC_API_URL=http://localhost:3333

# Partner API Security - REQUIRED when FF_PARTNER_AUTH=true
# AES-256-GCM key, 32 bytes hex. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIAL_ENCRYPTION_KEY=

# Timestamp tolerance for HMAC (ms, default 300000 = 5 min)
PARTNER_SIGNATURE_TTL=300000

# Rate limit (api-gateway)
RATE_LIMIT_TTL=60000
RATE_LIMIT_LIMIT=100

# Feature Flags
FF_PARTNER_AUTH=false
FF_CLAIMS_VALIDATION=false
FF_WALLET_PRESENTATIONS=false

# Frontend (Vite) - ops-console needs VITE_INTERNAL_API_KEY for Credentials page
# Must match INTERNAL_API_KEY when ops-console calls orchestration-api
VITE_INTERNAL_API_KEY=

# Redis (BullMQ - required for async webhook delivery)
REDIS_HOST=localhost
REDIS_PORT=6388
REDIS_PASSWORD=
REDIS_DB=0

# Queue (BullMQ)
QUEUE_PREFIX=ultima-forma
QUEUE_WEBHOOK_CONCURRENCY=5
QUEUE_NOTIFICATION_CONCURRENCY=3

# Production simulation: set INTERNAL_API_KEY and CREDENTIAL_ENCRYPTION_KEY, FF_PARTNER_AUTH=true
NODE_ENV=development
