# Database (used by docker-compose and DATABASE_URL)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=  # Set strong password for production
POSTGRES_DB=ultima_forma
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:55432/ultima_forma

# API Ports (optional - defaults shown)
API_GATEWAY_PORT=3333
ORCHESTRATION_API_PORT=3334

# Internal API key - when set, /internal/* endpoints require X-API-Key header
# ops-console must send VITE_INTERNAL_API_KEY (or configure fetch with this key)
# INTERNAL_API_KEY=your-secret-key

# User App (para consentUrl retornada pelo api-gateway)
# - localhost:8081: fluxo web no mesmo computador
# - Se testar no celular: use o IP da sua máquina na LAN (ex: http://192.168.1.5:8081)
USER_APP_URL=http://localhost:8081

# Expo user-app: API base URL injected into the web bundle
EXPO_PUBLIC_API_URL=http://localhost:3333

# Rate limit (api-gateway)
# RATE_LIMIT_TTL=60000
# RATE_LIMIT_LIMIT=100

# Partner API Security (MVP 2.0)
# Encryption key for integration credential secrets (AES-256-GCM, 32-byte hex)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CREDENTIAL_ENCRYPTION_KEY=

# Enable HMAC signature authentication for partner API requests
# PARTNER_AUTH_ENABLED=false

# Timestamp tolerance for partner signatures in milliseconds (default: 300000 = 5 min)
# PARTNER_AUTH_TIMESTAMP_TOLERANCE_MS=300000

# Node
NODE_ENV=development
