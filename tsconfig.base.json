{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@ultima-forma/shared-config": ["libs/shared/config/src/index.ts"],
      "@ultima-forma/shared-logger": ["libs/shared/logger/src/index.ts"],
      "@ultima-forma/shared-errors": ["libs/shared/errors/src/index.ts"],
      "@ultima-forma/infrastructure-db": [
        "libs/infrastructure/db/src/index.ts"
      ],
      "@ultima-forma/infrastructure-drizzle": [
        "libs/infrastructure/drizzle/src/index.ts"
      ],
      "@ultima-forma/infrastructure-queue": [
        "libs/infrastructure/queue/src/index.ts"
      ],
      "@ultima-forma/domain-partner": ["libs/domain/partner/src/index.ts"],
      "@ultima-forma/application-partner": [
        "libs/application/partner/src/index.ts"
      ],
      "@ultima-forma/application-jobs": [
        "libs/application/jobs/src/index.ts"
      ],
      "@ultima-forma/domain-consent": ["libs/domain/consent/src/index.ts"],
      "@ultima-forma/domain-audit": ["libs/domain/audit/src/index.ts"],
      "@ultima-forma/domain-webhook": ["libs/domain/webhook/src/index.ts"],
      "@ultima-forma/domain-jobs": ["libs/domain/jobs/src/index.ts"],
      "@ultima-forma/application-consent": [
        "libs/application/consent/src/index.ts"
      ],
      "@ultima-forma/shared-i18n": ["libs/shared/i18n/src/index.ts"],
      "@ultima-forma/shared-health": ["libs/shared/health/src/index.ts"],
      "@ultima-forma/infrastructure-feature-flags": [
        "libs/infrastructure/feature-flags/src/index.ts"
      ],
      "@ultima-forma/domain-claims": ["libs/domain/claims/src/index.ts"],
      "@ultima-forma/application-claims": [
        "libs/application/claims/src/index.ts"
      ],
      "@ultima-forma/domain-wallet": ["libs/domain/wallet/src/index.ts"],
      "@ultima-forma/application-wallet": [
        "libs/application/wallet/src/index.ts"
      ],
      "@ultima-forma/shared-design-tokens": [
        "libs/shared/design-tokens/src/index.ts"
      ],
      "@ultima-forma/shared-ui": ["libs/shared/ui/src/index.ts"],
      "@ultima-forma/shared-ui-native": [
        "libs/shared/ui-native/src/index.ts"
      ]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
