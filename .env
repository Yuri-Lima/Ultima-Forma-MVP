# Database (used by docker-compose and DATABASE_URL)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ultima_forma
DATABASE_URL=postgresql://postgres:postgres@localhost:55432/ultima_forma

# API Ports (optional - defaults shown)
API_GATEWAY_PORT=3333
ORCHESTRATION_API_PORT=3334

# User App (consentUrl) - use IP da LAN se testar no celular
USER_APP_URL=http://localhost:8081

# Expo user-app: API base URL injected into the web bundle
EXPO_PUBLIC_API_URL=http://localhost:3333

# Partner API Security (MVP 2.0)
# Encryption key for integration credential secrets (AES-256-GCM, 32-byte hex)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIAL_ENCRYPTION_KEY="271285619588903c1aa49fb2987ac1b1bf267bc2ed62eba5aff4b5ee385adf6c"

# Enable HMAC signature authentication for partner API requests
PARTNER_AUTH_ENABLED=false

# Timestamp tolerance for partner signatures in milliseconds (default: 300000 = 5 min)
PARTNER_AUTH_TIMESTAMP_TOLERANCE_MS=300000

# Node
NODE_ENV=development
