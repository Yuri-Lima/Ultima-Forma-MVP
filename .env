# Database (used by docker-compose and DATABASE_URL)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ultima_forma
DATABASE_URL=postgresql://postgres:postgres@localhost:55432/ultima_forma

# API Ports (optional - defaults shown)
API_GATEWAY_PORT=3333
ORCHESTRATION_API_PORT=3334

# Internal API key - REQUIRED for production simulation
# Protects /internal/* endpoints (orchestration-api). Ops Console sends via X-API-Key.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_KEY=0dd995fd94a5b545d4c82a6101d894e91f1ce7141b78cd32c970e41e177a65c9

# User App (consentUrl) - use IP da LAN se testar no celular
USER_APP_URL=http://localhost:8081

# Expo user-app: API base URL injected into the web bundle
EXPO_PUBLIC_API_URL=http://localhost:3333

# Partner API Security
# Encryption key for integration credential secrets (AES-256-GCM, 32-byte hex)
# REQUIRED when FF_PARTNER_AUTH=true. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIAL_ENCRYPTION_KEY=271285619588903c1aa49fb2987ac1b1bf267bc2ed62eba5aff4b5ee385adf6c

# Timestamp tolerance for partner signatures in milliseconds (default: 300000 = 5 min)
PARTNER_SIGNATURE_TTL=300000

# Rate limit (api-gateway)
RATE_LIMIT_TTL=60000
RATE_LIMIT_LIMIT=100

# Feature Flags - production-like (HMAC auth, claims validation, wallet)
FF_PARTNER_AUTH=false
FF_CLAIMS_VALIDATION=true
FF_WALLET_PRESENTATIONS=true

# Frontend (Vite) - ops-console uses VITE_INTERNAL_API_KEY for /internal/* calls
# Ops Console API: VITE_API_URL (default http://localhost:3334) - do not set if using defaults
# Partner Portal API: VITE_API_URL (default http://localhost:3333) - conflicts with ops; use per-app .env for production
VITE_INTERNAL_API_KEY=0dd995fd94a5b545d4c82a6101d894e91f1ce7141b78cd32c970e41e177a65c9

# Node - use "development" for local prod simulation (localhost DB allowed)
NODE_ENV=development

REDIS_PORT=6388

# Issuer Simulator
VITE_GATEWAY_URL=http://localhost:3333
ISSUER_SIMULATOR_URL=http://localhost:4202
