  "scripts": {
    "db:up": "docker compose -f docker/docker-compose.yml up -d",
    "db:down": "docker compose -f docker/docker-compose.yml down",
    "infra:up": "docker compose -f docker/docker-compose.yml up -d",
    "infra:down": "docker compose -f docker/docker-compose.yml down",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed.ts",
    "db:seed:dev": "tsx scripts/seed-dev.ts",
    "db:seed:prod": "tsx scripts/seed-prod.ts",
    "db:migrate:safe": "tsx scripts/migrate-safe.ts",
    "build:info": "tsx scripts/generate-build-info.ts",
    "test:api": "bash scripts/test-endpoints.sh",
    "i18n:extract": "pnpm exec i18next --config i18next-parser.config.js",
    "dev:gateway": "nx serve api-gateway",
    "dev:orchestration": "nx serve orchestration-api",
    "dev:worker": "nx serve worker",
    "dev:user-app": "nx run user-app:serve",
    "dev:user-app:prod": "cd apps/user-app && npx expo export --platform web --clear && npx expo serve",
    "dev:user-app:native": "nx run user-app:start",
    "dev:user-app:tunnel": "nx run user-app:start -- --tunnel",
    "dev:partner-portal": "nx serve partner-portal",
    "dev:ops-console": "nx serve ops-console",
    "dev:all": "pnpm build:info && pnpm db:migrate:safe && pnpm db:seed && pnpm i18n:extract && nx run-many -t serve -p api-gateway,orchestration-api,worker,user-app,partner-portal,ops-console --parallel"
  },
