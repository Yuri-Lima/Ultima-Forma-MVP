{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../dist/out-tsc",
    "declaration": true,
    "types": ["node"],
    "paths": {
      "@ultima-forma/infrastructure-drizzle": ["dist/libs/infrastructure/drizzle/src/index.d.ts"],
      "@ultima-forma/shared-config": ["dist/libs/shared/config/src/index.d.ts"],
      "@ultima-forma/shared-logger": ["dist/libs/shared/logger/src/index.d.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "jest.config.ts",
    "jest.config.cts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts"
  ]
}
