{
  "name": "domain-consent",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/domain/consent/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/domain/consent",
        "main": "libs/domain/consent/src/index.ts",
        "tsConfig": "libs/domain/consent/tsconfig.lib.json",
        "assets": ["libs/domain/consent/*.md"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/domain/consent/jest.config.cts"
      }
    }
  }
}
