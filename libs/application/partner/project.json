{
  "name": "app-partner",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/application/partner/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/application/partner",
        "main": "libs/application/partner/src/index.ts",
        "tsConfig": "libs/application/partner/tsconfig.lib.json",
        "assets": ["libs/application/partner/*.md"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/application/partner/jest.config.js",
        "passWithNoTests": true
      }
    }
  }
}
