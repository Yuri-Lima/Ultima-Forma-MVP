{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../dist/out-tsc",
    "declaration": true,
    "types": ["node"],
    "paths": {
      "@ultima-forma/shared-config": ["libs/shared/config/src/index.ts"],
      "@ultima-forma/shared-logger": ["libs/shared/logger/src/index.ts"],
      "@ultima-forma/shared-errors": ["libs/shared/errors/src/index.ts"],
      "@ultima-forma/infrastructure-db": ["libs/infrastructure/db/src/index.ts"],
      "@ultima-forma/infrastructure-drizzle": ["libs/infrastructure/drizzle/src/index.ts"],
      "@ultima-forma/domain-partner": ["libs/domain/partner/src/index.ts"],
      "@ultima-forma/application-partner": ["libs/application/partner/src/index.ts"],
      "@ultima-forma/domain-consent": ["libs/domain/consent/src/index.ts"],
      "@ultima-forma/domain-audit": ["dist/libs/domain/audit/src/index.d.ts"],
      "@ultima-forma/application-consent": ["libs/application/consent/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "jest.config.ts",
    "jest.config.cts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts"
  ]
}
