{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../dist/out-tsc",
    "declaration": true,
    "types": ["node"],
    "paths": {
      "@ultima-forma/domain-claims": ["dist/libs/domain/claims/src/index.d.ts"],
      "@ultima-forma/shared-errors": ["dist/libs/shared/errors/src/index.d.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "jest.config.ts",
    "jest.config.cts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts"
  ]
}
