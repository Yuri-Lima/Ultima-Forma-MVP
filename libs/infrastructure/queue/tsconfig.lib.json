{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../dist/out-tsc",
    "declaration": true,
    "types": ["node"],
    "paths": {
      "@ultima-forma/domain-jobs": ["dist/libs/domain/jobs/src/index.d.ts"],
      "@ultima-forma/domain-webhook": ["dist/libs/domain/webhook/src/index.d.ts"],
      "@ultima-forma/domain-audit": ["dist/libs/domain/audit/src/index.d.ts"],
      "@ultima-forma/shared-logger": ["dist/libs/shared/logger/src/index.d.ts"],
      "@ultima-forma/shared-config": ["dist/libs/shared/config/src/index.d.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts"
  ]
}
